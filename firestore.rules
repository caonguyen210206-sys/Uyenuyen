rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidVocabItem(data) {
      return data.keys().hasAll(['word', 'ipa', 'wordType', 'meaning', 'definition', 'example', 'synonyms', 'antonyms', 'band', 'topic', 'status', 'masteryLevel', 'source', 'createdAt', 'timesChecked', 'ownerId'])
        && data.word is string && data.word.size() <= 500
        && data.ipa is string && data.ipa.size() <= 500
        && data.wordType is string && data.wordType.size() <= 100
        && data.meaning is string && data.meaning.size() <= 2000
        && data.definition is string && data.definition.size() <= 2000
        && data.example is string && data.example.size() <= 2000
        && data.synonyms is string && data.synonyms.size() <= 1000
        && data.antonyms is string && data.antonyms.size() <= 1000
        && data.band is string && data.band.size() <= 100
        && data.topic is string && data.topic.size() <= 100
        && data.status in ['Storage', 'Studying', 'Completed']
        && data.masteryLevel in ['New', 'Beginner', 'Advanced', 'Mastery']
        && data.source is string && data.source.size() <= 1000
        && data.createdAt is number
        && data.timesChecked is number
        && data.ownerId == request.auth.uid;
    }

    function isValidQuizSession(data) {
      return data.keys().hasAll(['mode', 'questionCount', 'criteria', 'score', 'ownerId'])
        && data.mode in ['Vietnamese', 'Foreign']
        && data.questionCount is number
        && data.criteria is list && data.criteria.size() <= 10 && (data.criteria.size() == 0 || data.criteria[0] is string)
        && data.score is number
        && data.ownerId == request.auth.uid;
    }

    function isValidUserSettings(data) {
      return data.keys().hasAll(['apiKey', 'defaultQuestions', 'defaultCriteria', 'ownerId'])
        && data.apiKey is string && data.apiKey.size() <= 500
        && data.defaultQuestions is number
        && data.defaultCriteria is list && data.defaultCriteria.size() <= 10 && (data.defaultCriteria.size() == 0 || data.defaultCriteria[0] is string)
        && data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      match /vocabItems/{vocabItemId} {
        allow read: if isOwner(userId);
        
        allow create: if isOwner(userId) 
          && isValidId(vocabItemId) 
          && isValidVocabItem(incoming());
          
        allow update: if isOwner(userId) 
          && isValidId(vocabItemId) 
          && isValidVocabItem(incoming())
          && incoming().ownerId == existing().ownerId
          && incoming().createdAt == existing().createdAt;
          
        allow delete: if isOwner(userId);
      }
      
      match /quizSessions/{sessionId} {
        allow read: if isOwner(userId);
        
        allow create: if isOwner(userId) 
          && isValidId(sessionId) 
          && isValidQuizSession(incoming());
          
        allow update: if isOwner(userId) 
          && isValidId(sessionId) 
          && isValidQuizSession(incoming())
          && incoming().ownerId == existing().ownerId;
          
        allow delete: if isOwner(userId);
      }
      
      match /settings/{settingId} {
        allow read: if isOwner(userId);
        
        allow create: if isOwner(userId) 
          && isValidId(settingId) 
          && isValidUserSettings(incoming());
          
        allow update: if isOwner(userId) 
          && isValidId(settingId) 
          && isValidUserSettings(incoming())
          && incoming().ownerId == existing().ownerId;
          
        allow delete: if isOwner(userId);
      }
    }
  }
}
